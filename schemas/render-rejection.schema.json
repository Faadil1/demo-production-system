{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/dps/render-rejection.schema.json",
  "title": "RFC-0006 RenderRejection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "stage", "reasonCodes", "findings", "requirements", "inputArtifactIds", "provenance"],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "status": { "const": "rejected" },
    "stage": { "type": "string" },
    "reasonCodes": { "type": "array", "items": { "type": "string" } },
    "findings": { "type": "array", "items": { "$ref": "render-finding.schema.json" } },
    "requirements": { "type": "array" },
    "inputArtifactIds": { "type": "array", "items": { "type": "string" } },
    "provenance": { "type": "object" }
  }
}
