{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/dps/resolved-render-assets.schema.json",
  "title": "RFC-0006 ResolvedRenderAsset[]",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["schemaVersion", "id", "bindingId", "evidenceRefId", "source", "sourceContentHash", "mediaType", "byteLength", "preparationRequirementIds"],
    "properties": {
      "schemaVersion": { "const": "0.1" },
      "id": { "type": "string", "minLength": 1 },
      "bindingId": { "type": "string", "minLength": 1 },
      "evidenceRefId": { "type": "string", "minLength": 1 },
      "source": { "type": "object", "required": ["kind"] },
      "sourceContentHash": { "type": "string", "minLength": 1 },
      "mediaType": { "enum": ["image/png", "image/jpeg", "image/webp", "video/mp4", "video/webm", "audio/wav", "audio/mp3", "font/ttf", "font/woff2"] },
      "byteLength": { "type": "integer", "exclusiveMinimum": 0 },
      "intrinsicWidthPx": { "type": "integer", "exclusiveMinimum": 0 },
      "intrinsicHeightPx": { "type": "integer", "exclusiveMinimum": 0 },
      "intrinsicDurationMs": { "type": "integer", "exclusiveMinimum": 0 },
      "preparedArtifactId": { "type": "string" },
      "preparedContentHash": { "type": "string" },
      "preparationRequirementIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
    }
  }
}
