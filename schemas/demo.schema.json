{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/dps/demo.schema.json",
  "title": "DPS Demo Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "project",
    "demo",
    "product"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "problem",
        "audience",
        "valueProposition"
      ],
      "properties": {
        "problem": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "valueProposition": {
          "type": "string",
          "minLength": 1
        },
        "heroInteractionHint": {
          "type": "string"
        },
        "evidenceHints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "demo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "audience",
        "durationSeconds",
        "mode"
      ],
      "properties": {
        "goal": {
          "enum": [
            "explain",
            "convince",
            "prove",
            "onboard"
          ]
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "durationSeconds": {
          "type": "integer",
          "minimum": 10,
          "maximum": 600
        },
        "mode": {
          "enum": [
            "assisted",
            "directed",
            "autonomous"
          ]
        },
        "styles": {
          "type": "array",
          "items": {
            "enum": [
              "forensic",
              "operational",
              "editorial",
              "technical-proof",
              "cinematic",
              "hero-interaction"
            ]
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "noGeneratedUI": {
          "type": "boolean",
          "default": true
        },
        "minimumEvidenceCount": {
          "type": "integer",
          "minimum": 1
        },
        "maximumOnScreenWords": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}