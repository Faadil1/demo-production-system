{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/dps/adapter-capabilities.schema.json",
  "title": "RFC-0006 AdapterCapabilities",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "adapter",
    "declarationVersion",
    "supportedLayerKinds",
    "supportedMediaTypes",
    "supportedTransitions",
    "supportedTypographyFeatures",
    "supportedEffects",
    "widthRangePx",
    "heightRangePx",
    "supportedFrameRates",
    "supportedColorSpaces",
    "supportedAudioModes",
    "maximumLayerCountPerScene"
  ],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 } }
    },
    "declarationVersion": { "type": "string", "minLength": 1 },
    "supportedLayerKinds": { "type": "array", "items": { "enum": ["asset", "text", "shape", "reserved-region"] } },
    "supportedMediaTypes": {
      "type": "array",
      "items": { "enum": ["image/png", "image/jpeg", "image/webp", "video/mp4", "video/webm", "audio/wav", "audio/mp3", "font/ttf", "font/woff2"] }
    },
    "supportedTransitions": {
      "type": "array",
      "items": { "enum": ["cut", "hold", "cross-reveal", "replace", "focus", "continuity", "before-after", "proof-result", "conclusion"] }
    },
    "supportedTypographyFeatures": { "type": "array", "items": { "type": "string" } },
    "supportedEffects": { "type": "array", "items": { "type": "string" } },
    "widthRangePx": { "$ref": "#/$defs/capabilityRange" },
    "heightRangePx": { "$ref": "#/$defs/capabilityRange" },
    "supportedFrameRates": { "type": "array", "items": { "type": "object" } },
    "supportedColorSpaces": { "type": "array", "items": { "enum": ["srgb", "display-p3", "rec709"] } },
    "supportedAudioModes": { "type": "array", "items": { "enum": ["none", "optional", "required"] } },
    "maximumLayerCountPerScene": { "type": "integer", "exclusiveMinimum": 0 }
  },
  "$defs": {
    "capabilityRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum", "maximum"],
      "properties": { "minimum": { "type": "number" }, "maximum": { "type": "number" } }
    }
  }
}
